          "DataType": "MultipleLinesOfText",
          "MaxLength": 1048576,
          "Required": false
        },
        {
          "ColumnName": "msfer_definitionchecksum",
          "DisplayName": "Hash Definição",
          "Description": "_checksum da definição para detecção de alterações",
          "DataType": "SingleLineOfText",
          "MaxLength": 64,
          "Required": false
