          "Options": [
            { "Value": 1, "Label": "Ativado" },
            { "Value": 2, "Label": "Desativado" },
            { "Value": 3, "Label": "Rascunho" }
          ]
        },
        {
          "ColumnName": "msfer_type",
          "DisplayName": "Tipo",
          "Description": "Tipo do fluxo",
          "DataType": "Picklist",
          "Required": true,
          "Options": [
            { "Value": 1, "Label": "Fluxo de Nuvem" },
            { "Value": 2, "Label": "Instantâneo" },
            { "Value": 3, "Label": "Automático" },
            { "Value": 4, "Label": "Agendado" }
          ]
        },
        {
